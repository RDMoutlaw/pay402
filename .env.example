# pay402 configuration
# Copy to .env and fill in the wallets you want to use.
# You only need ONE wallet type — configure whichever rail you'll use.

# --- Lightning (L402) ---
# LND_HOST=https://your-lnd-node:8080
# LND_MACAROON=hex-encoded-admin-macaroon
# LND_TLS_CERT=base64-encoded-tls-cert  # optional, for self-signed nodes

# --- EVM / Base (x402) ---
# EVM_PRIVATE_KEY=0x...  # 32-byte hex private key
# EVM_CHAIN=base         # or base-sepolia for testnet
# EVM_FACILITATOR_URL=   # optional, defaults to https://x402.org/facilitate

# --- Solana (x402) ---
# SOLANA_SECRET_KEY=base58-encoded-keypair
# SOLANA_CLUSTER=mainnet-beta  # or devnet for testnet

# --- Spend controls ---
PAY402_MAX_PER_REQUEST=1.00
PAY402_MAX_DAILY=10.00
PAY402_LOG_LEVEL=info

# --- BTC price (for Lightning USD conversion) ---
# PAY402_BTC_PRICE_USD=60000  # or set PAY402_AUTO_BTC_PRICE=true
